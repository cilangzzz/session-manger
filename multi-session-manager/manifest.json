{
  "manifest_version": 3,
  "name": "Multi-Session Manager",
  "version": "1.0.0",
  "description": "Manage multiple isolated sessions per tab - same website, multiple accounts simultaneously",
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "tabGroups",
    "webRequest",
    "webRequestAuthProvider",
    "webNavigation",
    "contextMenus",
    "notifications",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "create-new-session": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "Create a new session"
    },
    "switch-session-next": {
      "suggested_key": { "default": "Ctrl+Shift+M" },
      "description": "Switch to next session for current tab"
    }
  }
}
